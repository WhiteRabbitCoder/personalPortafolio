# Spotify credentials — set these in Cloudflare Pages dashboard (Settings > Environment variables)
# For local development, copy this to .dev.vars (used by wrangler pages dev)

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# How to get these:
# 1. Create an app at https://developer.spotify.com/dashboard
# 2. Set redirect URI to http://localhost:5173/callback
# 3. Copy Client ID and Client Secret
# 4. Get a refresh token by running: npm run spotify:token
